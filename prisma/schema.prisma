generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ==========================================
// Authentication models
// ==========================================

model Identity {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  username          String  @unique
  email             String  @unique
  emailVerified     Boolean @default(false)
  accountStatus     String  @default("inactive")
  passwordHash      String?
  image             String?
  hiddenFromReports Boolean @default(false)
  // totpKey          Bytes?
  // twoFactorEnabled Boolean @default(false)

  // Role relation (replaces old string-based role field)
  roleId String? @db.ObjectId
  role   Role?   @relation(fields: [roleId], references: [id])

  // Platform super admin (developer / full access across tenants; separate from Role for multi-tenant)
  adminUser AdminUser?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions                 Session[]
  emailVerificationRequest EmailVerificationRequest?
  passwordResetTokens      PasswordResetToken[]

  saleReports    SaleReport[]
  workDayRecords WorkDayRecord[]
}

model Session {
  id                String   @id @map("_id") @db.String
  identityId        String   @db.ObjectId
  expiresAt         DateTime
  twoFactorVerified Boolean  @default(false)

  identity Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)
}

model EmailVerificationRequest {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identityId String   @unique @db.ObjectId
  code       String
  email      String
  expiresAt  DateTime

  identity Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  tokenHash  String   @id @map("_id")
  identityId String   @unique @db.ObjectId
  expiresAt  DateTime

  identity Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)
}

// ==========================================
// Platform super admins (developers); bypass all permission checks. Not tied to a tenant.
// ==========================================

model AdminUser {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identityId String   @unique @db.ObjectId
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)
}

model StoreSettings {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  uniqueKey String @unique @default("store")

  startCash       Int
  activePlatforms String[] @default(["uber_eats", "doordash", "skip_the_dishes", "ritual"])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SaleReport {
  id   String   @id @default(auto()) @map("_id") @db.ObjectId
  date DateTime @unique

  totalSales Int
  cardSales  Int

  platformSales PlatformSale[]

  expenses       Int
  expensesReason String?
  cardTips       Int
  cashTips       Int
  extraTips      Int
  cashInTill     Int
  startCash      Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  identityId String   @db.ObjectId
  reporter   Identity @relation(fields: [identityId], references: [id], onDelete: Restrict)

  auditLogs ReportAudit[]
}

type PlatformSale {
  platformId String
  amount     Int
}

type ReportAudit {
  identityId String   @db.ObjectId
  timestamp  DateTime
}

model Expense {
  id      String         @id @default(auto()) @map("_id") @db.ObjectId
  date    DateTime       @unique
  entries ExpenseEntry[]
}

type ExpenseEntry {
  amount Int
  reason String
}

// ==========================================
// WorkDayRecord (one document per employee per day)
// ==========================================

type WorkShift {
  startMinutes Int
  endMinutes   Int
  note         String?
}

model WorkDayRecord {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  date       DateTime
  identityId String      @db.ObjectId
  identity   Identity    @relation(fields: [identityId], references: [id], onDelete: Restrict)
  shifts     WorkShift[]
  totalHours Float
  tips       Int         @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, identityId])
}

// ==========================================
// Role-Based Access Control (RBAC) Models
// ==========================================

model Permission {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  code        String  @unique
  name        String
  description String?
  resource    String
  action      String

  roleIds String[] @db.ObjectId
  roles   Role[]   @relation(fields: [roleIds], references: [id])
}

model Role {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  editable    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  permissionIds String[]     @db.ObjectId
  permissions   Permission[] @relation(fields: [permissionIds], references: [id])

  identities Identity[]

  // Note: name uniqueness will be enforced at application level
  // When multi-tenant is added, this will become @@unique([name, tenantId])
}
