generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  username          String  @unique
  email             String  @unique
  emailVerified     Boolean @default(false)
  accountStatus     String  @default("inactive")
  passwordHash      String?
  image             String?
  hiddenFromReports Boolean @default(false)
  // totpKey          Bytes?
  // twoFactorEnabled Boolean @default(false)

  // Role relation (replaces old string-based role field)
  roleId String? @db.ObjectId
  role   Role?   @relation(fields: [roleId], references: [id])

  // Platform super admin (developer / full access across tenants; separate from Role for multi-tenant)
  adminUser AdminUser?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions                 Session[]
  emailVerificationRequest EmailVerificationRequest?
  passwordResetTokens      PasswordResetToken[]

  saleReports    SaleReport[]
  workDayRecords WorkDayRecord[]
}

model Session {
  id                String   @id @map("_id") @db.String
  userId            String   @db.ObjectId
  expiresAt         DateTime
  twoFactorVerified Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationRequest {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  code      String
  email     String
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  tokenHash String   @id @map("_id")
  userId    String   @unique @db.ObjectId
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Platform super admins (developers); bypass all permission checks. Not tied to a tenant.
model AdminUser {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StoreSettings {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  uniqueKey String @unique @default("store")

  startCash       Int
  activePlatforms String[] @default(["uber_eats", "doordash", "skip_the_dishes", "ritual"])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SaleReport {
  id   String   @id @default(auto()) @map("_id") @db.ObjectId
  date DateTime @unique

  totalSales Int
  cardSales  Int

  // Legacy platform columns (kept for backward compatibility)
  uberEatsSales      Int
  skipTheDishesSales Int
  doorDashSales      Int
  onlineSales        Int // This is actually Ritual sales
  // New flexible platform sales
  platformSales      PlatformSale[]

  expenses       Int
  expensesReason String?
  cardTips       Int
  cashTips       Int
  extraTips      Int
  cashInTill     Int
  startCash      Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId   String @db.ObjectId
  reporter User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  shifts    Shift[]
  auditLogs ReportAudit[]
}

type Shift {
  userId String @db.ObjectId
  hours  Float
  tips   Int
}

type PlatformSale {
  platformId String
  amount     Int
}

type ReportAudit {
  userId    String   @db.ObjectId
  timestamp DateTime
}

model Expense {
  id      String         @id @default(auto()) @map("_id") @db.ObjectId
  date    DateTime       @unique
  entries ExpenseEntry[]
}

type ExpenseEntry {
  amount Int
  reason String
}

// ==========================================
// WorkDayRecord (one document per employee per day)
// ==========================================

type WorkShift {
  startMinutes Int
  endMinutes   Int
  note         String?
}

model WorkDayRecord {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  date       DateTime
  userId     String      @db.ObjectId
  user       User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  shifts     WorkShift[]
  totalHours Float
  tips       Int         @default(0)
  note       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, userId])
}

// ==========================================
// Role-Based Access Control (RBAC) Models
// ==========================================

model Permission {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  code        String  @unique
  name        String
  description String?
  resource    String
  action      String

  roleIds String[] @db.ObjectId
  roles   Role[]   @relation(fields: [roleIds], references: [id])
}

model Role {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  editable    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  permissionIds String[]     @db.ObjectId
  permissions   Permission[] @relation(fields: [permissionIds], references: [id])

  users User[]

  // Note: name uniqueness will be enforced at application level
  // When multi-tenant is added, this will become @@unique([name, tenantId])
}
