{
  "name": "@serva/serva-ui",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint",
    "generate:component": "turbo gen react-component",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@serva/shared": "workspace:*",
    "@base-ui/react": "^1.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tw-animate-css": "^1.4.0",
    "tailwind-merge": "^3.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next-themes": "^0.4.6",
    "shadcn": "^4.1.1",
    "@hugeicons/core-free-icons": "^3.1.1",
    "@hugeicons/react": "^1.1.4"
  },
  "devDependencies": {
    "@serva/eslint-config": "workspace:*",
    "@serva/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.1.18",
    "@turbo/gen": "^2.8.1",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/node": "^20.19.27",
    "tailwindcss": "^4.1.18"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./globals.css": "./src/styles/globals.css",
    "./postcss.config": "./postcss.config.mjs",
    "./lib/*": "./src/lib/*.ts",
    "./constants/*": "./src/constants/*.ts",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./components/serva/*": "./src/components/serva/*.tsx",
    "./components/emails/*": "./src/components/emails/*.tsx"
  }
