generator client {
  provider      = "prisma-client"
  output        = "../generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ==========================================
// Authentication models
// ==========================================

model Identity {
  id            String  @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  accountStatus String  @default("inactive")
  passwordHash  String?
  image         String?
  // totpKey          Bytes?
  // twoFactorEnabled Boolean @default(false)

  // Platform super admin (developer / full access across tenants; separate from Role for multi-tenant)
  adminUser AdminUser?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions                 Session[]
  emailVerificationRequest EmailVerificationRequest?
  passwordResetTokens      PasswordResetToken[]

  operators   Operator[]
  employees   Employee[]
  saleReports SaleReport[]

  oauthAccounts Account[]
}

// Linked OAuth / SSO provider; Google `sub` is `accountId` when `providerId` is `google`.
model Account {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identityId String   @db.ObjectId
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  accountId  String // provider subject (e.g. Google `sub`)
  providerId String // provider ID (e.g. "google")

  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([providerId, accountId])
}

model Session {
  id                String   @id @map("_id") @db.String
  identityId        String   @db.ObjectId
  expiresAt         DateTime
  twoFactorVerified Boolean  @default(false)

  identity Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)
}

model EmailVerificationRequest {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identityId String   @unique @db.ObjectId
  code       String
  email      String
  expiresAt  DateTime

  identity Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  tokenHash  String   @id @map("_id")
  identityId String   @unique @db.ObjectId
  expiresAt  DateTime

  identity Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)
}

// ==========================================
// Platform super admins (developers); bypass all permission checks. Not tied to a tenant.
// ==========================================

model AdminUser {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identityId String   @unique @db.ObjectId
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)
}

// ==========================================
// Company (multi-tenant)
// ==========================================

model Company {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String
  slug String @unique

  settings       CompanySettings?
  locations      Location[]
  departments    Department[]
  roles          Role[]
  jobs           Job[]
  operators      Operator[]
  employees      Employee[]
  invites        Invite[]
  saleReports    SaleReport[]
  workDayRecords WorkDayRecord[]
  expenses       Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanySettings {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  startCash       Int
  activePlatforms String[]

  companyId String  @unique @db.ObjectId
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Location {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  employees Employee[]

  companyId String  @db.ObjectId
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
}

model Department {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  employees Employee[]

  companyId String  @db.ObjectId
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
}

model Operator {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  identityId String   @db.ObjectId
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  companyId String  @db.ObjectId
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  roleId String? @db.ObjectId
  role   Role?   @relation(fields: [roleId], references: [id])

  status String @default("awaiting")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([identityId, companyId])
}

model Job {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String

  companyId String  @db.ObjectId
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  employees Employee[]
  invites   Invite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
}

model Employee {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  identityId String   @db.ObjectId
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  companyId String  @db.ObjectId
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  jobId String? @db.ObjectId
  job   Job?    @relation(fields: [jobId], references: [id])

  status String @default("awaiting")

  locationId String?   @db.ObjectId
  location   Location? @relation(fields: [locationId], references: [id])

  departmentId String?     @db.ObjectId
  department   Department? @relation(fields: [departmentId], references: [id])

  workDayRecords WorkDayRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invite {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  companyId String  @db.ObjectId
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name        String
  email       String
  profileType String // "operator" | "employee"
  roleId      String? @db.ObjectId
  role        Role?   @relation(fields: [roleId], references: [id], onDelete: SetNull)
  jobId       String? @db.ObjectId
  job         Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  token      String    @unique
  status     String    @default("awaiting") // awaiting | accepted | expired | revoked
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([companyId, profileType, status])
  @@index([email, status])
}

model SaleReport {
  id   String   @id @default(auto()) @map("_id") @db.ObjectId
  date DateTime @unique

  totalSales     Int
  cardSales      Int
  platformSales  PlatformSale[]
  expenses       Int
  expensesReason String?
  cardTips       Int
  cashTips       Int
  extraTips      Int
  cashInTill     Int
  startCash      Int

  companyId String  @db.ObjectId
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  identityId String   @db.ObjectId
  reporter   Identity @relation(fields: [identityId], references: [id], onDelete: Restrict)

  auditLogs ReportAudit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

type PlatformSale {
  platformId String
  amount     Int
}

type ReportAudit {
  identityId String   @db.ObjectId
  timestamp  DateTime
}

model Expense {
  id        String         @id @default(auto()) @map("_id") @db.ObjectId
  date      DateTime       @unique
  companyId String         @db.ObjectId
  company   Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  entries   ExpenseEntry[]
}

type ExpenseEntry {
  amount Int
  reason String
}

// ==========================================
// WorkDayRecord (one document per employee per day)
// ==========================================

type WorkShift {
  startMinutes Int
  endMinutes   Int
  note         String?
}

model WorkDayRecord {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  date       DateTime
  shifts     WorkShift[]
  totalHours Float
  tips       Int         @default(0)

  employeeId String   @db.ObjectId
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  companyId String  @db.ObjectId
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, employeeId])
}

// ==========================================
// Role-Based Access Control (RBAC) Models
// ==========================================

model Permission {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  code        String  @unique
  name        String
  description String?
  resource    String
  action      String

  roleIds String[] @db.ObjectId
  roles   Role[]   @relation(fields: [roleIds], references: [id])
}

model Role {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  editable    Boolean @default(true)

  companyId String  @db.ObjectId
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  permissionIds String[]     @db.ObjectId
  permissions   Permission[] @relation(fields: [permissionIds], references: [id])

  operators Operator[]
  invites   Invite[]

  @@unique([companyId, name])
}
