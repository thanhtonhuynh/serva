{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": ["{workspaceRoot}/tsconfig.base.json"]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build", "^db:generate"],
      "cache": true
    },
    "db:generate": {
      "cache": false
    },
    "dev": {
      "cache": false
    },
    "lint": {
      "cache": true
    }
  },
  "analytics": false
}
