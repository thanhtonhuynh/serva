{
  "name": "serva",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nx run @serva/web:dev",
    "build": "nx run @serva/web:build",
    "lint": "nx run-many -t lint",
    "dev:all": "nx run-many -t dev"
  },
  "devDependencies": {
    "nx": "^21.3.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "nx",
      "prisma",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  },
  "prettier": {
    "printWidth": 100,
    "plugins": [
      "prettier-plugin-tailwindcss"
    ]
  }
}
