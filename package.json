{
  "name": "serva",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web": "nx run @serva/web:dev",
    "dev:auth": "nx run @serva/auth-app:dev",
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "dev:all": "nx run-many -t dev",
    "postinstall": "pnpm --filter @serva/database run db:generate"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@date-fns/tz": "^1.4.1",
    "@date-fns/utc": "^2.1.1",
    "@hugeicons/core-free-icons": "^3.1.1",
    "@hugeicons/react": "^1.1.4",
    "@node-rs/argon2": "^2.0.2",
    "@oslojs/binary": "^1.0.0",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@oslojs/otp": "^1.1.0",
    "next": "16.1.6",
    "nodemailer": "^7.0.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.479.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "@hookform/resolvers": "^5.2.2",
    "react-day-picker": "^9.13.0",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "server-only": "^0.0.1",
    "zod": "^4.3.6",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.4.0",
    "@react-email/components": "^1.0.1"
  },
  "devDependencies": {
    "@serva/database": "workspace:*",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20.19.27",
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3",
    "nx": "^21.3.2",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "shadcn": "^4.1.1",
    "tailwindcss": "^4.1.18",
    "@types/nodemailer": "^6.4.21",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "nx",
      "prisma",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  },
  "prettier": {
    "printWidth": 100,
    "plugins": [
      "prettier-plugin-tailwindcss"
    ]
  }
}
