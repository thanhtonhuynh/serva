{
  "name": "serva",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nx run @serva/web:dev",
    "build": "nx run @serva/web:build",
    "lint": "nx run-many -t lint",
    "dev:all": "nx run-many -t dev",
    "postinstall": "pnpm --filter @serva/database run db:generate"
  },
  "devDependencies": {
    "@serva/database": "workspace:*",
    "nx": "^21.3.2",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@date-fns/tz": "^1.4.1",
    "@date-fns/utc": "^2.1.1",
    "date-fns": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "nx",
      "prisma",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  },
  "prettier": {
    "printWidth": 100,
    "plugins": [
      "prettier-plugin-tailwindcss"
    ]
  }
}
