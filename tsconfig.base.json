{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "baseUrl": ".",
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "target": "ES2023",
    "paths": {
      "@serva/database": ["libs/database/src/index.ts"],
      "@serva/shared": ["libs/shared/src/index.ts"],
      "@serva/ui": ["libs/ui/src/index.ts"],
      "@serva/ui/*": ["libs/ui/src/*"]
    }
  },
  "exclude": ["node_modules"]
}
