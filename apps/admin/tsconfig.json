{
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@serva/database": ["../../libs/database/src/index.ts"],
      "@serva/shared": ["../../libs/shared/src/index.ts"],
      "@serva/shared/*": ["../../libs/shared/src/*"],
      "@serva/auth": ["../../libs/auth/src/index.ts"],
      "@serva/auth/*": ["../../libs/auth/src/*"],
      "@serva/serva-ui": ["../../libs/serva-ui/src/index.ts"],
      "@serva/serva-ui/*": ["../../libs/serva-ui/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"],
  "extends": "../../tsconfig.base.json"
}
