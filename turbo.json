{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "db:push": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "build": {
      "description": "Compiles TypeScript and bundles the application",
      "dependsOn": ["^build", "@serva/database#db:push"],
      "env": [
        "DATABASE_URL",
        "AUTH_URL",
        "WEB_URL",
        "ADMIN_URL",
        "GMAIL_USER",
        "GMAIL_PASS",
        "BLOB_READ_WRITE_TOKEN",
        "COOKIE_DOMAIN",
        "MAINTENANCE_MODE",
        "MAINTENANCE_BYPASS_TOKEN",
        "NODE_ENV",
        "PLATFORM_COMPANY_IMPERSONATION_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "description": "Checks code style and catches common errors",
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "description": "Checks for type errors",
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "description": "Starts the development server",
      "cache": false,
      "persistent": true
    }
  }
}
